<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:include filename="dn_act_segment.xacro" />

  <!-- 1. Macro da Parte Central da Perna -->
  <xacro:macro name="center_leg" params="prefix parent *origin">
    
    <!-- Junta que conecta o segmento ao link pai 'prefix=l, r' -->
    <joint name="${parent}_${prefix}_up_leg_conn_joint" type="revolute">
      <xacro:insert_block name="origin" />
      <parent link="${parent}" />
      <child link="${prefix}_up_leg_conn" />
      <axis xyz="1 0 0" />
      <limit lower="-1.0" upper="1.0" effort="100" velocity="1.0"/>
    </joint>

    <link name="${prefix}_up_leg_conn">
      <visual>
        <geometry>
          <mesh filename="package://alice_xacro_desc/meshes/up_femur.stl" />
        </geometry>
      </visual>
      <inertial>
        <mass value="1.0" />
        <origin xyz="0 0 0" rpy="0 0 0" />
        <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01" />
      </inertial>
    </link>

    <link name="${prefix}_l_up_front_leg">
      <visual>
        <geometry>
          <mesh filename="package://alice_xacro_desc/meshes/front_up_l.stl" />
        </geometry>
      </visual>
      <inertial>
        <mass value="1.0" />
        <origin xyz="0 0 0" rpy="0 0 0" />
        <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01" />
      </inertial>
    </link>

    <joint
      name="${prefix}_up_leg_conn_${prefix}_l_up_front_leg_joint"
      type="continuous">
      <origin
        xyz="0.065 0.043 -0.05"
        rpy="0 0 0" />
      <parent
        link="${prefix}_up_leg_conn" />
      <child
        link="${prefix}_l_up_front_leg" />
      <axis
        xyz="0 1 0" />
    </joint>

    <link name="${prefix}_r_up_front_leg">
      <visual>
        <geometry>
          <mesh filename="package://alice_xacro_desc/meshes/front_up_r.stl" />
        </geometry>
      </visual>
      <inertial>
        <mass value="1.0" />
        <origin xyz="0 0 0" rpy="0 0 0" />
        <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01" />
      </inertial>
    </link>

    <joint
      name="${prefix}_up_leg_conn_${prefix}_r_up_front_leg_joint"
      type="continuous">
      <origin
        xyz="0.065 -0.043 -0.05"
        rpy="0 0 0" />
      <parent
        link="${prefix}_up_leg_conn" />
      <child
        link="${prefix}_r_up_front_leg" />
      <axis
        xyz="0 1 0" />
    </joint>

    <link name="${prefix}_up_back_leg">
      <visual>
        <geometry>
          <mesh filename="package://alice_xacro_desc/meshes/back_leg.stl" />
        </geometry>
      </visual>
      <inertial>
        <mass value="1.0" />
        <origin xyz="0 0 0" rpy="0 0 0" />
        <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01" />
      </inertial>
    </link>

    <joint
      name="${prefix}_up_leg_conn_${prefix}_up_back_leg_joint"
      type="continuous">
      <origin
        xyz="-0.065 0 -0.05"
        rpy="0 0 0" />
      <parent
        link="${prefix}_up_leg_conn" />
      <child
        link="${prefix}_up_back_leg" />
      <axis
        xyz="0 1 0" />
    </joint>

    <link name="${prefix}_knee">
      <visual>
        <geometry>
          <mesh filename="package://alice_xacro_desc/meshes/knee.stl" />
        </geometry>
      </visual>
      <inertial>
        <mass value="1.0" />
        <origin xyz="0 0 0" rpy="0 0 0" />
        <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01" />
      </inertial>
    </link>

    <joint
      name="${prefix}_up_back_leg_${prefix}_knee_joint"
      type="continuous">
      <origin
        xyz="0 0 -0.265"
        rpy="0 0 0" />
      <parent
        link="${prefix}_up_back_leg" />
      <child
        link="${prefix}_knee" />
      <axis
        xyz="0 1 0" />
    </joint>

    <link name="${prefix}_l_dn_front_leg">
      <visual>
        <geometry>
          <mesh filename="package://alice_xacro_desc/meshes/front_dn_l.stl" />
        </geometry>
      </visual>
      <inertial>
        <mass value="1.0" />
        <origin xyz="0 0 0" rpy="0 0 0" />
        <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01" />
      </inertial>
    </link>

    <joint
      name="${prefix}_knee_${prefix}_l_dn_front_leg_joint"
      type="continuous">
      <origin
        xyz="0.130 0.043 -0.04"
        rpy="0 0 0" />
      <parent
        link="${prefix}_knee" />
      <child
        link="${prefix}_l_dn_front_leg" />
      <axis
        xyz="0 1 0" />
    </joint>

    <!-- INSERIR AQUI APÊNDICE DE ATUADORES L -->
    <xacro:dn_actuator_segment prefix="${prefix}_l" parent="${prefix}_l_dn_front_leg">
      <origin xyz="-0.042 -0.00050907 -0.0215" rpy="0 0 0" />
    </xacro:dn_actuator_segment>

    <link name="${prefix}_dn_back_leg">
      <visual>
        <geometry>
          <mesh filename="package://alice_xacro_desc/meshes/back_leg.stl" />
        </geometry>
      </visual>
      <inertial>
        <mass value="1.0" />
        <origin xyz="0 0 0" rpy="0 0 0" />
        <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01" />
      </inertial>
    </link>

    <joint
      name="${prefix}_knee_${prefix}_dn_back_leg_joint"
      type="continuous">
      <origin
        xyz="0 0 -0.04"
        rpy="0 0 0" />
      <parent
        link="${prefix}_knee" />
      <child
        link="${prefix}_dn_back_leg" />
      <axis
        xyz="0 1 0" />
    </joint>

    <link name="${prefix}_ankle">
      <visual>
        <geometry>
          <mesh filename="package://alice_xacro_desc/meshes/dn_ankle.stl" />
        </geometry>
      </visual>
      <inertial>
        <mass value="1.0" />
        <origin xyz="0 0 0" rpy="0 0 0" />
        <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01" />
      </inertial>
    </link>

    <joint
      name="${prefix}_dn_back_leg_${prefix}_ankle_joint"
      type="continuous">
      <origin
        xyz="0 0 -0.265"
        rpy="0 0 0" />
      <parent
        link="${prefix}_dn_back_leg" />
      <child
        link="${prefix}_ankle" />
      <axis
        xyz="0 1 0" />
    </joint>

    <link name="${prefix}_foot">
      <visual>
        <geometry>
          <mesh filename="package://alice_xacro_desc/meshes/foot.stl" />
        </geometry>
      </visual>
      <inertial>
        <mass value="1.0" />
        <origin xyz="0 0 0" rpy="0 0 0" />
        <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01" />
      </inertial>
    </link>

    <joint
      name="${prefix}_ankle_${prefix}_foot_joint"
      type="continuous">
      <origin
        xyz="0.065 0 -0.05"
        rpy="0 0 0" />
      <parent
        link="${prefix}_ankle" />
      <child
        link="${prefix}_foot" />
      <axis
        xyz="1 0 0" />
    </joint>

    <link name="${prefix}_r_dn_front_leg">
      <visual>
        <geometry>
          <mesh filename="package://alice_xacro_desc/meshes/front_dn_r.stl" />
        </geometry>
      </visual>
      <inertial>
        <mass value="1.0" />
        <origin xyz="0 0 0" rpy="0 0 0" />
        <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01" />
      </inertial>
    </link>

    <joint
      name="${prefix}_knee_${prefix}_r_dn_front_leg_joint"
      type="continuous">
      <origin
        xyz="0.130 -0.043 -0.04"
        rpy="0 0 0" />
      <parent
        link="${prefix}_knee" />
      <child
        link="${prefix}_r_dn_front_leg" />
      <axis
        xyz="0 1 0" />
    </joint>

    <!-- INSERIR AQUI APÊNDICE DE ATUADORES R -->
    <xacro:dn_actuator_segment prefix="${prefix}_r" parent="${prefix}_r_dn_front_leg">
      <origin xyz="-0.042 -0.00050907 -0.0215" rpy="0 0 0" />
    </xacro:dn_actuator_segment>

    <!-- Aqui você continuaria declarando as juntas (ex: prismática para o atuador) e links (haste, conector final) usando sempre ${prefix}_nome_do_link -->

  </xacro:macro>


</robot>