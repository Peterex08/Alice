<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Macro do braço esquerdo -->
  <xacro:macro name="head" params="parent *origin">
    
    <joint name="${parent}_yaw_head_joint" type="revolute">
      <xacro:insert_block name="origin" />
      <parent link="${parent}" />
      <child link="yaw_head" />
      <axis xyz="0 0 1" />
      <limit lower="-1.0" upper="1.0" effort="100" velocity="1.0"/>
    </joint>

    <link name="yaw_head">
      <visual>
        <geometry>
          <!-- Reutilizando o mesmo STL -->
          <mesh filename="package://alice_xacro_desc/meshes/head1.stl" />
        </geometry>
      </visual>
      <inertial>
        <mass value="1.0" />
        <origin xyz="0 0 0" rpy="0 0 0" />
        <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01" />
      </inertial>
    </link>

    <link name="pitch_head">
      <visual>
        <geometry>
          <!-- Reutilizando o mesmo STL -->
          <mesh filename="package://alice_xacro_desc/meshes/head2.stl" />
        </geometry>
      </visual>
      <inertial>
        <mass value="1.0" />
        <origin xyz="0 0 0" rpy="0 0 0" />
        <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01" />
      </inertial>
    </link>

    <joint
      name="yaw_head_pitch_head_joint"
      type="continuous">
      <origin
        xyz="0 -0.023 0.04145"
        rpy="0 0 0" />
      <parent
        link="yaw_head" />
      <child
        link="pitch_head" />
      <axis
        xyz="0 1 0" />
    </joint>

  </xacro:macro>

</robot>