<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Macro do braço esquerdo -->
  <xacro:macro name="left_arm" params="parent *origin">
    
    <joint name="${parent}_l_arm_tri_joint" type="revolute">
      <xacro:insert_block name="origin" />
      <parent link="${parent}" />
      <child link="l_arm_tri" />
      <axis xyz="0 1 0" />
      <limit lower="-1.0" upper="1.0" effort="100" velocity="1.0"/>
    </joint>

    <link name="l_arm_tri">
      <visual>
        <geometry>
          <!-- Reutilizando o mesmo STL -->
          <mesh filename="package://alice_xacro_desc/meshes/larm1.stl" />
        </geometry>
      </visual>
      <inertial>
        <origin xyz="0.00280 0.01782 -0.06268" rpy="0 0 0"/>
        <mass value="0.25180"/>
        <inertia
            ixx="0.003326125"
            ixy="0.000001544"
            ixz="0.000075089"
            iyy="0.003336491"
            iyz="-0.000034114"
            izz="0.000059530"/>
      </inertial>
    </link>

    <link name="l_arm_haste">
      <visual>
        <geometry>
          <!-- Reutilizando o mesmo STL -->
          <mesh filename="package://alice_xacro_desc/meshes/up_haste.stl" />
        </geometry>
      </visual>
      <inertial>
        <origin xyz="0.0 0.0 -0.05194" rpy="0 0 0"/>
        <mass value="0.29579"/>
        <inertia
            ixx="0.000366379"
            ixy="0.0"
            ixz="0.0"
            iyy="0.000366533"
            iyz="0.0"
            izz="0.000014856"/>
      </inertial>
    </link>

    <joint
      name="l_arm_tri_l_arm_haste_joint"
      type="continuous">
      <origin
        xyz="0.039 0.02 0.04376106"
        rpy="0 0 0" />
      <parent
        link="l_arm_tri" />
      <child
        link="l_arm_haste" />
      <axis
        xyz="0 1 0" />
    </joint>

    <link name="l_arm_atuador">
      <visual>
        <geometry>
          <!-- Reutilizando o mesmo STL -->
          <mesh filename="package://alice_xacro_desc/meshes/up_actuator.stl" />
        </geometry>
      </visual>
      <inertial>
        <origin xyz="-0.01764 -0.00010 -0.09055" rpy="0 0 0"/>
        <mass value="0.34367"/>
        <inertia
            ixx="0.000927312"
            ixy="0.000000789"
            ixz="0.000065314"
            iyy="0.001049676"
            iyz="0.000001769"
            izz="0.000190178"/>
      </inertial>
    </link>

    <joint
      name="l_arm_haste_l_arm_atuador_joint"
      type="prismatic">
      <origin
        xyz="0 0 -0.075"
        rpy="0 0 3.14159" />
      <parent
        link="l_arm_haste" />
      <child
        link="l_arm_atuador" />
      <axis
        xyz="0 0 1" />
      <limit
        lower="-0.2"
        upper="0.2"
        effort="100"
        velocity="1" />
    </joint>

    <link name="l_arm_ant">
      <visual>
        <geometry>
          <!-- Reutilizando o mesmo STL -->
          <mesh filename="package://alice_xacro_desc/meshes/larm2.stl" />
        </geometry>
      </visual>
      <inertial>
        <origin xyz="0.11743 0.00195 0.00186" rpy="0 0 0"/>
        <mass value="0.34308"/>
        <inertia
            ixx="0.000076037"
            ixy="0.000113102"
            ixz="-0.000034335"
            iyy="0.003507890"
            iyz="-0.000002022"
            izz="0.003475583"/>
      </inertial>
    </link>

    <joint
      name="l_arm_tri_l_arm_ant_joint"
      type="continuous">
      <origin
        xyz="0 0.02 -0.25523894"
        rpy="0 0 0" />
      <parent
        link="l_arm_tri" />
      <child
        link="l_arm_ant" />
      <axis
        xyz="0 1 0" />
    </joint>

  </xacro:macro>

    <!-- Macro do braço direito -->
  <xacro:macro name="right_arm" params="parent *origin">
    
    <joint name="${parent}_r_arm_tri_joint" type="revolute">
      <xacro:insert_block name="origin" />
      <parent link="${parent}" />
      <child link="r_arm_tri" />
      <axis xyz="0 1 0" />
      <limit lower="-1.0" upper="1.0" effort="100" velocity="1.0"/>
    </joint>

    <link name="r_arm_tri">
      <visual>
        <geometry>
          <!-- Reutilizando o mesmo STL -->
          <mesh filename="package://alice_xacro_desc/meshes/rarm1.stl" />
        </geometry>
      </visual>
      <inertial>
        <origin xyz="0.00307 -0.01783 -0.06332" rpy="0 0 0"/>
        <mass value="0.25180"/>
        <inertia
            ixx="0.003330078"
            ixy="-0.000001676"
            ixz="0.000081997"
            iyy="0.003341524"
            iyz="0.000035021"
            izz="0.000060631"/>
      </inertial>
    </link>

    <link name="r_arm_haste">
      <visual>
        <geometry>
          <!-- Reutilizando o mesmo STL -->
          <mesh filename="package://alice_xacro_desc/meshes/up_haste.stl" />
        </geometry>
      </visual>
      <inertial>
        <origin xyz="0.0 0.0 -0.05194" rpy="0 0 0"/>
        <mass value="0.29579"/>
        <inertia
            ixx="0.000366379"
            ixy="0.0"
            ixz="0.0"
            iyy="0.000366533"
            iyz="0.0"
            izz="0.000014856"/>
      </inertial>
    </link>

    <joint
      name="r_arm_tri_r_arm_haste_joint"
      type="continuous">
      <origin
        xyz="0.040 -0.02 0.043"
        rpy="0 0 0" />
      <parent
        link="r_arm_tri" />
      <child
        link="r_arm_haste" />
      <axis
        xyz="0 1 0" />
    </joint>

    <link name="r_arm_atuador">
      <visual>
        <geometry>
          <!-- Reutilizando o mesmo STL -->
          <mesh filename="package://alice_xacro_desc/meshes/up_actuator.stl" />
        </geometry>
      </visual>
      <inertial>
        <origin xyz="-0.01764 -0.00010 -0.09055" rpy="0 0 0"/>
        <mass value="0.34367"/>
        <inertia
            ixx="0.000927312"
            ixy="0.000000789"
            ixz="0.000065314"
            iyy="0.001049676"
            iyz="0.000001769"
            izz="0.000190178"/>
      </inertial>
    </link>

    <joint
      name="r_arm_haste_r_arm_atuador_joint"
      type="prismatic">
      <origin
        xyz="0 0 -0.075"
        rpy="0 0 3.14159" />
      <parent
        link="r_arm_haste" />
      <child
        link="r_arm_atuador" />
      <axis
        xyz="0 0 1" />
      <limit
        lower="-0.2"
        upper="0.2"
        effort="100"
        velocity="1" />
    </joint>

    <link name="r_arm_ant">
      <visual>
        <geometry>
          <!-- Reutilizando o mesmo STL -->
          <mesh filename="package://alice_xacro_desc/meshes/rarm2.stl" />
        </geometry>
      </visual>
      <inertial>
        <origin xyz="0.16920 -0.00421 0.00107" rpy="0 0 0"/>
        <mass value="0.05993"/>
        <inertia
            ixx="0.000017279"
            ixy="-0.000028339"
            ixz="-0.000011329"
            iyy="0.000716453"
            iyz="0.000000559"
            izz="0.000707547"/>
      </inertial>
    </link>

    <joint
      name="r_arm_tri_r_arm_ant_joint"
      type="continuous">
      <origin
        xyz="0 -0.020 -0.256"
        rpy="0 0 0" />
      <parent
        link="r_arm_tri" />
      <child
        link="r_arm_ant" />
      <axis
        xyz="0 1 0" />
    </joint>

  </xacro:macro>

</robot>