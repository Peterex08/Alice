<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Macro do braço esquerdo -->
  <xacro:macro name="head" params="parent *origin">
    
    <joint name="${parent}_yaw_head_joint" type="revolute">
      <xacro:insert_block name="origin" />
      <parent link="${parent}" />
      <child link="yaw_head" />
      <axis xyz="0 0 1" />
      <limit lower="-1.0" upper="1.0" effort="100" velocity="1.0"/>
    </joint>

    <link name="yaw_head">
      <visual>
        <geometry>
          <!-- Reutilizando o mesmo STL -->
          <mesh filename="package://alice_xacro_desc/meshes/head1.stl" />
        </geometry>
      </visual>
      <inertial>
        <origin xyz="0.0 -0.00358 0.03195" rpy="0 0 0"/>
        <mass value="0.05815"/>
        <inertia
            ixx="0.000023285"
            ixy="0.000000000"
            ixz="-0.000000074"
            iyy="0.000015710"
            iyz="-0.000001654"
            izz="0.000012426"/>
      </inertial>
    </link>

    <link name="pitch_head">
      <visual>
        <geometry>
          <!-- Reutilizando o mesmo STL -->
          <mesh filename="package://alice_xacro_desc/meshes/head2.stl" />
        </geometry>
      </visual>
      <inertial>
        <origin xyz="-0.00377 0.02101 0.03408" rpy="0 0 0"/>
        <mass value="0.02883"/>
        <inertia
            ixx="0.000024978"
            ixy="0.000000460"
            ixz="-0.000000341"
            iyy="0.000008037"
            iyz="0.000001562"
            izz="0.000020981"/>
      </inertial>
    </link>

    <joint
      name="yaw_head_pitch_head_joint"
      type="continuous">
      <origin
        xyz="0 -0.023 0.04145"
        rpy="0 0 0" />
      <parent
        link="yaw_head" />
      <child
        link="pitch_head" />
      <axis
        xyz="0 1 0" />
    </joint>

  </xacro:macro>

</robot>