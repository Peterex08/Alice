<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:include filename="dn_act_segment.xacro" />

  <!-- 1. Macro da Parte Central da Perna -->
  <xacro:macro name="center_leg" params="prefix parent *origin">
    
    <!-- Junta que conecta o segmento ao link pai 'prefix=l, r' -->
    <joint name="${parent}_${prefix}_up_leg_conn_joint" type="revolute">
      <xacro:insert_block name="origin" />
      <parent link="${parent}" />
      <child link="${prefix}_up_leg_conn" />
      <axis xyz="1 0 0" />
      <limit lower="-1.0" upper="1.0" effort="100" velocity="1.0"/>
    </joint>

    <link name="${prefix}_up_leg_conn">
      <visual>
        <geometry>
          <mesh filename="package://alice_xacro_desc/meshes/up_femur.stl" />
        </geometry>
      </visual>
      <inertial>
        <origin xyz="0.01573 0.0 -0.03029" rpy="0 0 0"/>
        <mass value="0.19958"/>
        <inertia
            ixx="0.000146896"
            ixy="0.000000005"
            ixz="0.000001640"
            iyy="0.000591330"
            iyz="-0.000000001"
            izz="0.000653006"/>
      </inertial>
    </link>

    <link name="${prefix}_l_up_front_leg">
      <visual>
        <geometry>
          <mesh filename="package://alice_xacro_desc/meshes/front_up_l.stl" />
        </geometry>
      </visual>
      <inertial>
        <origin xyz="-0.00179 0.00049 -0.15908" rpy="0 0 0"/>
        <mass value="0.16694"/>
        <inertia
            ixx="0.001216063"
            ixy="0.000000454"
            ixz="0.000024719"
            iyy="0.001207669"
            iyz="-0.000002534"
            izz="0.000035329"/>
      </inertial>
    </link>

    <joint
      name="${prefix}_up_leg_conn_${prefix}_l_up_front_leg_joint"
      type="continuous">
      <origin
        xyz="0.065 0.043 -0.05"
        rpy="0 0 0" />
      <parent
        link="${prefix}_up_leg_conn" />
      <child
        link="${prefix}_l_up_front_leg" />
      <axis
        xyz="0 1 0" />
    </joint>

    <link name="${prefix}_r_up_front_leg">
      <visual>
        <geometry>
          <mesh filename="package://alice_xacro_desc/meshes/front_up_r.stl" />
        </geometry>
      </visual>
      <inertial>
        <origin xyz="-0.00179 -0.00050 -0.15908" rpy="0 0 0"/>
        <mass value="0.16694"/>
        <inertia
            ixx="0.001216064"
            ixy="-0.000000423"
            ixz="0.000024728"
            iyy="0.001207666"
            iyz="0.000002535"
            izz="0.000035328"/>
      </inertial>
    </link>

    <joint
      name="${prefix}_up_leg_conn_${prefix}_r_up_front_leg_joint"
      type="continuous">
      <origin
        xyz="0.065 -0.043 -0.05"
        rpy="0 0 0" />
      <parent
        link="${prefix}_up_leg_conn" />
      <child
        link="${prefix}_r_up_front_leg" />
      <axis
        xyz="0 1 0" />
    </joint>

    <link name="${prefix}_up_back_leg">
      <visual>
        <geometry>
          <mesh filename="package://alice_xacro_desc/meshes/back_leg.stl" />
        </geometry>
      </visual>
      <inertial>
        <origin xyz="-0.00193 0.0 -0.13250" rpy="0 0 0"/>
        <mass value="0.15327"/>
        <inertia
            ixx="0.001187219"
            ixy="0.000000002"
            ixz="0.0"
            iyy="0.001173746"
            iyz="0.0"
            izz="0.000029652"/>
      </inertial>
    </link>

    <joint
      name="${prefix}_up_leg_conn_${prefix}_up_back_leg_joint"
      type="continuous">
      <origin
        xyz="-0.065 0 -0.05"
        rpy="0 0 0" />
      <parent
        link="${prefix}_up_leg_conn" />
      <child
        link="${prefix}_up_back_leg" />
      <axis
        xyz="0 1 0" />
    </joint>

    <link name="${prefix}_knee">
      <visual>
        <geometry>
          <mesh filename="package://alice_xacro_desc/meshes/knee.stl" />
        </geometry>
      </visual>
      <inertial>
        <origin xyz="0.07992 0.0 -0.02000" rpy="0 0 0"/>
        <mass value="0.20036"/>
        <inertia
            ixx="0.000187723"
            ixy="0.000000002"
            ixz="-0.000000009"
            iyy="0.000646427"
            iyz="-0.000000001"
            izz="0.000747166"/>
      </inertial>
    </link>

    <joint
      name="${prefix}_up_back_leg_${prefix}_knee_joint"
      type="continuous">
      <origin
        xyz="0 0 -0.265"
        rpy="0 0 0" />
      <parent
        link="${prefix}_up_back_leg" />
      <child
        link="${prefix}_knee" />
      <axis
        xyz="0 1 0" />
    </joint>

    <link name="${prefix}_l_dn_front_leg">
      <visual>
        <geometry>
          <mesh filename="package://alice_xacro_desc/meshes/front_dn_l.stl" />
        </geometry>
      </visual>
      <inertial>
        <origin xyz="-0.00179 0.00050 -0.10592" rpy="0 0 0"/>
        <mass value="0.16694"/>
        <inertia
            ixx="0.001216061"
            ixy="0.000000453"
            ixz="-0.000024719"
            iyy="0.001207669"
            iyz="0.000002625"
            izz="0.000035328"/>
      </inertial>
    </link>

    <joint
      name="${prefix}_knee_${prefix}_l_dn_front_leg_joint"
      type="continuous">
      <origin
        xyz="0.130 0.043 -0.04"
        rpy="0 0 0" />
      <parent
        link="${prefix}_knee" />
      <child
        link="${prefix}_l_dn_front_leg" />
      <axis
        xyz="0 1 0" />
    </joint>

    <!-- INSERIR AQUI APÊNDICE DE ATUADORES L -->
    <xacro:dn_actuator_segment prefix="${prefix}_l" parent="${prefix}_l_dn_front_leg">
      <origin xyz="-0.042 -0.00050907 -0.0215" rpy="0 0 0" />
    </xacro:dn_actuator_segment>

    <link name="${prefix}_dn_back_leg">
      <visual>
        <geometry>
          <mesh filename="package://alice_xacro_desc/meshes/back_leg.stl" />
        </geometry>
      </visual>
      <inertial>
        <origin xyz="-0.00193 0.0 -0.13250" rpy="0 0 0"/>
        <mass value="0.15327"/>
        <inertia
            ixx="0.001187219"
            ixy="0.000000002"
            ixz="0.0"
            iyy="0.001173746"
            iyz="0.0"
            izz="0.000029652"/>
      </inertial>
    </link>

    <joint
      name="${prefix}_knee_${prefix}_dn_back_leg_joint"
      type="continuous">
      <origin
        xyz="0 0 -0.04"
        rpy="0 0 0" />
      <parent
        link="${prefix}_knee" />
      <child
        link="${prefix}_dn_back_leg" />
      <axis
        xyz="0 1 0" />
    </joint>

    <link name="${prefix}_ankle">
      <visual>
        <geometry>
          <mesh filename="package://alice_xacro_desc/meshes/dn_ankle.stl" />
        </geometry>
      </visual>
      <inertial>
        <origin xyz="0.08073 0.0 -0.01971" rpy="0 0 0"/>
        <mass value="0.19958"/>
        <inertia
            ixx="0.000146896"
            ixy="-0.000000005"
            ixz="-0.000001640"
            iyy="0.000591330"
            iyz="-0.000000001"
            izz="0.000653006"/>
      </inertial>
    </link>

    <joint
      name="${prefix}_dn_back_leg_${prefix}_ankle_joint"
      type="continuous">
      <origin
        xyz="0 0 -0.265"
        rpy="0 0 0" />
      <parent
        link="${prefix}_dn_back_leg" />
      <child
        link="${prefix}_ankle" />
      <axis
        xyz="0 1 0" />
    </joint>

    <link name="${prefix}_foot">
      <visual>
        <geometry>
          <mesh filename="package://alice_xacro_desc/meshes/foot.stl" />
        </geometry>
      </visual>
      <inertial>
        <origin xyz="0.00570 0.00006 -0.02799" rpy="0 0 0"/>
        <mass value="0.70863"/>
        <inertia
            ixx="0.001359548"
            ixy="0.000003941"
            ixz="-0.000094799"
            iyy="0.005895969"
            iyz="0.000000955"
            izz="0.006798208"/>
      </inertial>
    </link>

    <joint
      name="${prefix}_ankle_${prefix}_foot_joint"
      type="continuous">
      <origin
        xyz="0.065 0 -0.05"
        rpy="0 0 0" />
      <parent
        link="${prefix}_ankle" />
      <child
        link="${prefix}_foot" />
      <axis
        xyz="1 0 0" />
    </joint>

    <link name="${prefix}_r_dn_front_leg">
      <visual>
        <geometry>
          <mesh filename="package://alice_xacro_desc/meshes/front_dn_r.stl" />
        </geometry>
      </visual>
      <inertial>
        <origin xyz="-0.00179 -0.00049 -0.10592" rpy="0 0 0"/>
        <mass value="0.16694"/>
        <inertia
            ixx="0.001216063"
            ixy="-0.000000454"
            ixz="-0.000024719"
            iyy="0.001207669"
            iyz="-0.000002534"
            izz="0.000035329"/>
      </inertial>
    </link>

    <joint
      name="${prefix}_knee_${prefix}_r_dn_front_leg_joint"
      type="continuous">
      <origin
        xyz="0.130 -0.043 -0.04"
        rpy="0 0 0" />
      <parent
        link="${prefix}_knee" />
      <child
        link="${prefix}_r_dn_front_leg" />
      <axis
        xyz="0 1 0" />
    </joint>

    <!-- INSERIR AQUI APÊNDICE DE ATUADORES R -->
    <xacro:dn_actuator_segment prefix="${prefix}_r" parent="${prefix}_r_dn_front_leg">
      <origin xyz="-0.042 -0.00050907 -0.0215" rpy="0 0 0" />
    </xacro:dn_actuator_segment>

    <!-- Aqui você continuaria declarando as juntas (ex: prismática para o atuador) e links (haste, conector final) usando sempre ${prefix}_nome_do_link -->

  </xacro:macro>


</robot>