<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- 1. Macro do Segmento Repetitivo -->
  <xacro:macro name="dn_actuator_segment" params="prefix parent *origin">
    
    <!-- Junta que conecta o segmento ao link pai 'prefix=l_l, l_r, r_l, r_r' -->
    <joint name="${parent}_${prefix}_dn_up_leg_conn_joint" type="revolute">
      <xacro:insert_block name="origin" />
      <parent link="${parent}" />
      <child link="${prefix}_dn_up_leg_conn" />
      <axis xyz="1 0 0" />
      <limit lower="-1.0" upper="1.0" effort="100" velocity="1.0"/>
    </joint>

    <link name="${prefix}_dn_up_leg_conn">
      <visual>
        <geometry>
          <!-- Reutilizando o mesmo STL -->
          <mesh filename="package://alice_xacro_desc/meshes/dn_actuator_lig.stl" />
        </geometry>
      </visual>
      <inertial>
        <origin xyz="0.00042 0.0 -0.00470" rpy="0 0 0"/>
        <mass value="0.04607"/>
        <inertia
            ixx="0.000014850"
            ixy="0.0"
            ixz="-0.000000203"
            iyy="0.000009828"
            iyz="0.0"
            izz="0.000013705"/>
      </inertial>
    </link>

    <link name="${prefix}_dn_atuador">
      <visual>
        <geometry>
          <!-- Reutilizando o mesmo STL -->
          <mesh filename="package://alice_xacro_desc/meshes/dn_actuator.stl" />
        </geometry>
      </visual>
      <inertial>
        <origin xyz="-0.01598 0.00023 -0.07947" rpy="0 0 0"/>
        <mass value="0.34367"/>
        <inertia
            ixx="0.000927312"
            ixy="-0.000000789"
            ixz="-0.000065314"
            iyy="0.001049676"
            iyz="0.000001769"
            izz="0.000190178"/>
      </inertial>
    </link>

    <joint
      name="${prefix}_dn_up_leg_conn_${prefix}_dn_atuador_joint"
      type="continuous">
      <origin
        xyz="-0.008 0 -0.0185"
        rpy="0 0 0" />
      <parent
        link="${prefix}_dn_up_leg_conn" />
      <child
        link="${prefix}_dn_atuador" />
      <axis
        xyz="0 1 0" />
    </joint>

    <link name="${prefix}_dn_haste">
      <visual>
        <geometry>
          <!-- Reutilizando o mesmo STL -->
          <mesh filename="package://alice_xacro_desc/meshes/dn_haste.stl" />
        </geometry>
      </visual>
      <inertial>
        <origin xyz="0.0 0.0 0.05194" rpy="0 0 0"/>
        <mass value="0.29579"/>
        <inertia
            ixx="0.000366379"
            ixy="-0.00000000001"
            ixz="0.0"
            iyy="0.000366533"
            iyz="0.00000000001"
            izz="0.000014856"/>
      </inertial>
    </link>

    <joint
      name="${prefix}_dn_atuador_${prefix}_dn_haste_joint"
      type="prismatic">
      <origin
        xyz="0.001651 0 -0.245017"
        rpy="0 0 0" />
      <parent
        link="${prefix}_dn_atuador" />
      <child
        link="${prefix}_dn_haste" />
      <axis
        xyz="0 0 1" />
      <limit
        lower="-0.2"
        upper="0.2"
        effort="100"
        velocity="1" />
    </joint>

    <link name="${prefix}_dn_leg_conn">
      <visual>
        <geometry>
          <!-- Reutilizando o mesmo STL -->
          <mesh filename="package://alice_xacro_desc/meshes/dn_haste_lig.stl" />
        </geometry>
      </visual>
      <inertial>
        <origin xyz="-0.00039 0.0 -0.02349" rpy="0 0 0"/>
        <mass value="0.07743"/>
        <inertia
            ixx="0.000026847"
            ixy="-0.00000000048"
            ixz="0.000000217"
            iyy="0.000055486"
            iyz="0.00000000002"
            izz="0.000055266"/>
      </inertial>
    </link>

    <joint
      name="${prefix}_dn_haste_${prefix}_dn_dn_leg_conn_joint"
      type="continuous">
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <parent
        link="${prefix}_dn_haste" />
      <child
        link="${prefix}_dn_leg_conn" />
      <axis
        xyz="0 1 0" />
    </joint>

    

    <!-- Aqui você continuaria declarando as juntas (ex: prismática para o atuador) e links (haste, conector final) usando sempre ${prefix}_nome_do_link -->

  </xacro:macro>


</robot>